# ─────────────────────────────────────────────────────────────────────────────
# Google AI
# ─────────────────────────────────────────────────────────────────────────────

# Your Gemini API key (obtainable from https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=AIzaSyBGIbQMb


# ─────────────────────────────────────────────────────────────────────────────
# Google Cloud Platform
# ─────────────────────────────────────────────────────────────────────────────

# Your GCP project ID
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Path to your service account JSON key file
# (Not required on Cloud Run when using Workload Identity)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# GCS bucket name (must already exist in your project)
GCS_BUCKET_NAME=caos-mark-vault


# ─────────────────────────────────────────────────────────────────────────────
# CAOS watermark parameters
# ─────────────────────────────────────────────────────────────────────────────

# Arnold's Cat Map iteration count — acts as the secret key
CAOS_ITERATIONS=8

# DCT-QIM quantisation strength (higher = more robust but slightly visible)
CAOS_STRENGTH=15.0


# ─────────────────────────────────────────────────────────────────────────────
# Development / local mode
# ─────────────────────────────────────────────────────────────────────────────

# Set to "true" to skip GCS/Firestore and use local disk instead
LOCAL_FALLBACK=true

# URL of the React frontend (for CORS)
FRONTEND_URL=http://localhost:5173
